<ContentPage
    x:Class="Maui.Diagnostics.Playground.Features.DiagnosticsFiles.DiagnosticsFilesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}"
    Shell.TabBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,36" Spacing="20">
            <Button
                Text="Back to gallery"
                HorizontalOptions="Start"
                Command="{Binding BackCommand}" />

            <Border
                Padding="22"
                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}"
                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Diagnostics files"
                        FontAttributes="Bold"
                        FontSize="30"
                        TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                        SemanticProperties.HeadingLevel="Level1" />
                    <Label
                        Text="App-private crash artifacts that can be listed, inspected, and shared from the device."
                        FontSize="16"
                        LineBreakMode="WordWrap"
                        TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                    <Label
                        Text="{Binding StatusText}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    <HorizontalStackLayout Spacing="12">
                        <Button
                            Text="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding IsNotLoading}" />
                        <Button
                            Text="Share all"
                            Command="{Binding ShareAllCommand}"
                            IsEnabled="{Binding HasFiles}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <CollectionView
                ItemsSource="{Binding Artifacts}"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,14"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeShape="RoundRectangle 20">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                <Label
                                    Text="{Binding Name}"
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    LineBreakMode="TailTruncation"
                                    TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                                <Label
                                    Grid.Row="1"
                                    Text="{Binding SummaryText}"
                                    FontSize="13"
                                    LineBreakMode="WordWrap"
                                    TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                                <HorizontalStackLayout
                                    Grid.Row="2"
                                    Spacing="10">
                                    <Button
                                        Text="View"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenFileCommand}"
                                        CommandParameter="{Binding .}" />
                                    <Button
                                        Text="Share"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShareFileCommand}"
                                        CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
